              {
                "type": "string",
                "description": "Path, URI, or caller-managed handle."
              },
              {
                "type": "array",
                "description": "Inline array-like numeric values."
              },
              {
                "type": "object",
                "description": "Typed wrapper, mapping, DataFrame-like object, or caller-side structured payload."
              }
            ]
