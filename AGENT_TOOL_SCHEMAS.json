    {
      "name": "ts_route",
      "description": "Route a natural-language time-series task to the smallest useful tsontology tool and expected output.",
      "input_schema": {
        "type": "object",
        "properties": {
          "task": {
            "type": "string"
          },
          "available_inputs": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Optional caller-side hints such as ['data_ref'] or ['left_ref', 'right_ref']."
          },
          "has_reference": {
            "type": "boolean"
          },
          "safe": {
            "type": "boolean"
          }
        },
        "required": [
